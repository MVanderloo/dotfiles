clipboard-read = allow
clipboard-write = allow

quit-after-last-window-closed = true

# wrap shell with tmux
command = sh -c 'while true; do tmux new-session \; set-option destroy-unattached on || { echo "tmux exited with $?"; read _; break; }; done'

confirm-close-surface = false

window-decoration = false

# enable ligatures
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss07
font-feature = ss08
font-feature = ss09
font-feature = calt
font-feature = liga

window-padding-x = 8
window-padding-y = 8

window-inherit-working-directory = false

keybind = clear
keybind = super+ctrl+r=reload_config
keybind = super+==increase_font_size:1
keybind = super++=increase_font_size:1
keybind = super+-=decrease_font_size:1
keybind = paste=paste_from_clipboard
keybind = super+v=paste_from_clipboard
keybind = ctrl+v=paste_from_clipboard

# load configs from ./local (if it exists) after this file has loaded
config-file = "?local"
theme = noctalia
