# load configs from ./local (if it exists) after this file has loaded
config-file = "?local"

quit-after-last-window-closed = true

# wrap shell with tmux
command = sh -c 'eval "$(/opt/homebrew/bin/brew shellenv)" && while true; do tmux new-session \; set-option destroy-unattached on || { echo "tmux exited with $?"; read _; break; }; done'

confirm-close-surface = false

# enable ligatures
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss07
font-feature = ss08
font-feature = ss09
font-feature = calt
font-feature = liga

window-padding-x = 8
window-padding-y = 8

macos-titlebar-style = hidden
macos-dock-drop-behavior = window

macos-icon = custom-style
macos-icon-frame = plastic
macos-icon-ghost-color = black
macos-icon-screen-color = black

window-inherit-working-directory = false

# keybindings
keybind = clear
keybind = super+ctrl+r=reload_config
keybind = super+==increase_font_size:1
keybind = super++=increase_font_size:1
keybind = super+-=decrease_font_size:1
# keybind = copy=copy_to_clipboard:mixed
keybind = paste=paste_from_clipboard
keybind = super+v=paste_from_clipboard
