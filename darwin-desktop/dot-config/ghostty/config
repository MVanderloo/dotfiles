# load configs from ./local (if it exists) after this file has loaded
config-file = "?local"

quit-after-last-window-closed = true

cursor-opacity=0.5

# no confirmation on close, use tmux!
confirm-close-surface = false

# enable ligatures
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss07
font-feature = ss08
font-feature = ss09
font-feature = calt
font-feature = liga

window-padding-x = 0
window-padding-y = 8,0
# window-padding-color = extend

macos-titlebar-style = hidden
macos-dock-drop-behavior = window

macos-icon = custom-style
macos-icon-frame = plastic
macos-icon-ghost-color = black
macos-icon-screen-color = black

window-vsync = false
window-inherit-working-directory = false

# keybindings
keybind = cmd+ctrl+r=reload_config
