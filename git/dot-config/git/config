    username = MVanderloo

[core]

[alias]
graph = log --graph --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)' --all
graph2 = log --graph --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(auto)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)'
    editor = nvim
    pager = delta
    excludesFile = ~/.config/git/ignore

[init]
    autosetupmerge = always
    autosetuprebase = always
    defaultBranch = main

[commit]
    gpg = true

[rerere]
  enabled = 1
; [pull]
    ; rebase = true
    ; ff = only


[interactive]
    diffFilter = delta --color-only --features=interactive


[merge]
    conflictstyle = diff3

[diff]
    colorMoved = zebra

[delta]
    navigate = true
    features = decorations
    line-numbers = true
    hyperlinks = true

[delta "interactive"]
    keep-plus-minus-markers = false
    show-syntax-highlighting = true
    color-syntax = true

[delta "decorations"]
    commit-decoration-style = blue ol
    commit-style = raw
    file-style = omit
    hunk-header-decoration-style = blue box
    hunk-header-file-style = red
    hunk-header-line-number-style = "#067a00"
    hunk-header-style = file line-number syntax

