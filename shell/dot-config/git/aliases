[alias]
	co = "checkout"
	sm = "submodule"
	sw = "switch"
	st = "status"
	graph = "log --graph --all"
	ignore = "!f() { IFS=','; curl -sL \"https://www.toptal.com/developers/gitignore/api/$*\"; }; f"
	stashgrep = "!f() { for i in $(git stash list --format='%gd'); do git stash show -p $i | grep -H --label=\"$i\" \"$@\"; done; } f"
