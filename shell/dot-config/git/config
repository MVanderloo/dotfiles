[user]
email = "me@mvanderloo.com"
name = "Michael van der Loo"

[include]
  path = aliases
	path = delta
	path = difftool
  path = disable-advice
  path = local # put machine local configs here

[branch]
	sort = -committerdate
	autosetupmerge = always
	autosetuprebase = remote

[diff]
	colorMoved = true

[tag]
	sort = -version:refname

[init]
	defaultBranch = main

[status]
	branch = true
	showStash = true
	showUntrackedFiles = all

[commit]
	verbose = true

[core]
	compression = 9
	whitespace = trailing-space
	preloadindex = true

[diff]
	algorithm = histogram
	colorMoved = zebra
	colorMovedWS = allow-indentation-change
	context = 8
	renames = copies
	interHunkContext = 10
	mnemonicPrefix = true

[interactive]
	singlekey = true

[push]
	autosetupremote = true
	default = current

[pull]
	rebase = merges

[rerere]
	enabled = 1
	autoupdate = true

[rebase]
	autostash = true
	autosquash = true

[merge]
	conflictstyle = zdiff3
	autostash = true

[submodule]
	recurse = true

[maintenance]
	auto = true
	strategy = incremental

[format]
	pretty = "format:%C(yellow)%h%C(reset)%C(auto)%d%C(reset) - %C(white)%s%C(reset) %C(blue)(%ar)%C(reset) %C(dim white)- %an%C(reset)"

[url "https://github.com/"]
	insteadOf = "gh:"

[url "https://gitlab.com/"]
	insteadOf = "gl:"

[url "https://github.com/mvanderloo/"]
	insteadOf = "my:"
