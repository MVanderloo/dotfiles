[user]
	email = "me@mvanderloo.com"
	name = "Michael van der Loo"

[include]
	path = aliases
	path = delta
	path = difftool
	path = disable-advice
	path = local # put machine local configs here

[url "git@github.com:MVanderloo/"]
	insteadOf = "my:"

[url "git@github.com:"]
	insteadOf = "gh:"

[url "git@gitlab.com:"]
	insteadOf = "gl:"

[url "git@codeberg.org:"]
	insteadOf = "cb:"

[branch]
	autosetupmerge = always
	autosetuprebase = remote
	sort = -committerdate

[commit]
	verbose = true

[core]
	compression = 9
	logAllRefUpdates = true
	preloadindex = true
	whitespace = trailing-space

[diff]
	algorithm = histogram
	colorMoved = zebra
	colorMovedWS = allow-indentation-change
	context = 8
	interHunkContext = 10
	mnemonicPrefix = true
	renames = copies

[format]
	pretty = "format:%C(yellow)%h%C(reset)%C(auto)%d%C(reset) - %C(white)%s%C(reset) %C(blue)(%ar)%C(reset) %C(dim white)- %an%C(reset)"

[init]
	defaultBranch = main

[interactive]
	singlekey = true

[maintenance]
	auto = true
	strategy = incremental

[merge]
	autostash = true
	conflictstyle = zdiff3

[push]
	autosetupremote = true
	default = current

[pull]
	rebase = merges

[rerere]
	autoupdate = true
	enabled = 1

[rebase]
	autosquash = true
	autostash = true

[submodule]
	fetchJobs = 0
	recurse = true

[status]
	branch = true
	showStash = true
	showUntrackedFiles = all

[tag]
	sort = -version:refname

